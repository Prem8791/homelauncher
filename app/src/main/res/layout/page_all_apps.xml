<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Content: Alphabet strips + Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="100">

        <!-- LEFT COLUMN: A–M + # -->
        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="8"
            android:background="@color/column_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <TextView android:id="@+id/letter_A" style="@style/AlphabetLetter" android:text="A" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_B" style="@style/AlphabetLetter" android:text="B" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_C" style="@style/AlphabetLetter" android:text="C" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_D" style="@style/AlphabetLetter" android:text="D" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_E" style="@style/AlphabetLetter" android:text="E" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_F" style="@style/AlphabetLetter" android:text="F" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_G" style="@style/AlphabetLetter" android:text="G" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_H" style="@style/AlphabetLetter" android:text="H" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_I" style="@style/AlphabetLetter" android:text="I" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_J" style="@style/AlphabetLetter" android:text="J" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_K" style="@style/AlphabetLetter" android:text="K" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_L" style="@style/AlphabetLetter" android:text="L" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_M" style="@style/AlphabetLetter" android:text="M" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_HASH" style="@style/AlphabetLetter" android:text="#" />
        </LinearLayout>

        <!-- Vertical Boundary -->
        <View style="@style/VerticalBoundary" />

        <!-- CENTER: App Grid -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="84"
            android:orientation="vertical"
            android:padding="4dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/allAppsGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false" />
        </LinearLayout>

        <!-- Vertical Boundary -->
        <View style="@style/VerticalBoundary" />

        <!-- RIGHT COLUMN: N–Z + * -->
        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="8"
            android:background="@color/column_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp">

            <TextView android:id="@+id/letter_N" style="@style/AlphabetLetter" android:text="N" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_O" style="@style/AlphabetLetter" android:text="O" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_P" style="@style/AlphabetLetter" android:text="P" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_Q" style="@style/AlphabetLetter" android:text="Q" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_R" style="@style/AlphabetLetter" android:text="R" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_S" style="@style/AlphabetLetter" android:text="S" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_T" style="@style/AlphabetLetter" android:text="T" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_U" style="@style/AlphabetLetter" android:text="U" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_V" style="@style/AlphabetLetter" android:text="V" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_W" style="@style/AlphabetLetter" android:text="W" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_X" style="@style/AlphabetLetter" android:text="X" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_Y" style="@style/AlphabetLetter" android:text="Y" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_Z" style="@style/AlphabetLetter" android:text="Z" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_STAR" style="@style/AlphabetLetter" android:text="*" />
            <View style="@style/AlphabetSeparator" />
            <TextView android:id="@+id/letter_ALL" style="@style/AlphabetLetter" android:text="◉" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
