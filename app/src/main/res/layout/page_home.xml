<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="100">

    <!-- Recent Apps Area -->
    <RelativeLayout
        android:id="@+id/recentAppsRow"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="80"
        android:background="@color/background">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recentAppsGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="4dp" />
    </RelativeLayout>

    <!-- Section Boundary -->
    <View style="@style/SectionBoundary" />

    <!-- Status Area - three columns: left (kill all), center (stats), right (settings) -->
    <LinearLayout
        android:id="@+id/statusArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:background="@color/stats_bar_bg"
        android:orientation="horizontal"
        android:weightSum="100">

        <!-- Left 15%: Kill All -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="15"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/killAllButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/kill_all_bg"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:text="@string/kill_all"
                android:textAllCaps="true"
                android:textColor="@color/text_primary"
                android:textSize="7sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Center 70%: System Stats (2 rows) -->
        <LinearLayout
            android:id="@+id/statusStatsCenter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="70"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:orientation="vertical"
            android:weightSum="10">

            <!-- Stats Row 1: Battery, RAM, CPU -->
            <LinearLayout
                android:id="@+id/statusStatsRow1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/statBattery"
                    style="@style/StatText"
                    android:text="--%" />
                <TextView
                    android:id="@+id/statRam"
                    style="@style/StatText"
                    android:text="--/--" />
                <TextView
                    android:id="@+id/statCpu"
                    style="@style/StatText"
                    android:text="--%" />
            </LinearLayout>

            <!-- Stats Row 2: Temp, Storage -->
            <LinearLayout
                android:id="@+id/statusStatsRow2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/statTemp"
                    style="@style/StatText"
                    android:text="--°C" />
                <TextView
                    android:id="@+id/statStorage"
                    style="@style/StatText"
                    android:text="--%" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right 15%: Settings -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="15"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/settingsButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/kill_all_bg"
                android:gravity="center"
                android:text="⚙"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Section Boundary -->
    <View style="@style/SectionBoundary" />

    <!-- Dock Area - small padding left/right, equal distribution -->
    <LinearLayout
        android:id="@+id/dockContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:background="@color/dock_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingVertical="4dp"
        android:weightSum="5" />
</LinearLayout>
